# ローカルでは未設定でもこの値が使われます。
COMPILE_API_URL=http://127.0.0.1:4000/compile

# Compiler API側（ローカル）
HOST=127.0.0.1
PORT=4000
COMPILER_RUNTIME=docker
TEX_IMAGE=latex-mvp-texlive:local
MAX_CONCURRENT=2
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# 通常は未設定（OSの一時ディレクトリを使用）
# WORK_ROOT=/absolute/path/to/writable/temp
